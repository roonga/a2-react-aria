{
	"name": "a2-react-aria",
	"private": true,
	"author": {
		"name": "Ravi Mohan",
		"email": "a2-react-aria@roonga.com.au",
		"url": "https://github.com/roonga"
	},
	"license": "MIT",
	"packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
	"engines": {
		"node": ">=20",
		"pnpm": ">=10"
	},
	"scripts": {
		"build": "turbo run build",
		"build:registry": "node scripts/build-registry.mts",
		"build:storybook": "storybook build",
		"dev": "turbo run dev --parallel",
		"test": "turbo run test",
		"test:visual": "playwright test",
		"test:visual:update": "playwright test --update-snapshots",
		"test:e2e": "playwright test --config playwright.e2e.config.ts",
		"test:e2e:headed": "HEADED=1 playwright test --config playwright.e2e.config.ts",
		"storybook": "storybook dev -p 6006",
		"lint": "biome check .",
		"format": "biome format . --write",
		"lint:md": "markdownlint-cli2 \"**/*.md\" \"!**/node_modules/**\"",
		"format:md": "markdownlint-cli2 --fix \"**/*.md\" \"!**/node_modules/**\"",
		"typedoc": "typedoc",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm build && changeset publish"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@swc/core",
			"esbuild",
			"sharp"
		]
	},
	"devDependencies": {
		"@a2ra/cli": "workspace:*",
		"@a2ra/core": "workspace:*",
		"@biomejs/biome": "2.4.16",
		"@changesets/cli": "^2.31.0",
		"@playwright/test": "^1.60.0",
		"@storybook/addon-a11y": "^10.4.4",
		"@storybook/addon-docs": "^10.4.4",
		"@storybook/addon-mcp": "^0.6.0",
		"@storybook/addon-themes": "^10.4.4",
		"@storybook/react-vite": "^10.4.4",
		"@tailwindcss/vite": "^4.3.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"markdownlint-cli2": "^0.17.2",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"storybook": "^10.4.4",
		"tailwindcss": "^4.3.0",
		"turbo": "latest",
		"typedoc": "^0.28.19",
		"typescript": "6.0.3"
	}
}
