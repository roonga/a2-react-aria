# LM Studio Configuration
# Copy this file to .env and adjust values as needed.

# API key — LM Studio doesn't enforce auth; any non-empty value works.
OPENAI_API_KEY=lm-studio

# LM Studio server endpoint.
# Use localhost:1234 when running locally (uv run python main.py).
# Docker uses host.docker.internal:1234 automatically via docker-compose.yml.
OPENAI_BASE_URL=http://localhost:1234/v1
