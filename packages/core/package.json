{
	"name": "@a2ui/core",
	"version": "0.1.0",
	"private": false,
	"author": {
		"name": "Ravi Mohan",
		"email": "a2-react-aria@roonga.com.au",
		"url": "https://github.com/roonga"
	},
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "vite build && tsc --emitDeclarationOnly --outDir dist",
		"dev": "vite build --watch",
		"gen-schema": "node --experimental-strip-types scripts/gen-schema.mts",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"react-aria-components": "^1.18.0",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitejs/plugin-react-swc": "^4.3.1",
		"axe-core": "^4.12.1",
		"jsdom": "^26.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"typescript": "6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
