{
	"name": "@a2ra/core",
	"version": "1.0.0-preview.5",
	"private": false,
	"description": "Render a2UI JSON as accessible React Aria components: A2Renderer, component registry, and Zod schemas.",
	"author": {
		"name": "Ravi Mohan",
		"email": "a2-react-aria@roonga.com.au",
		"url": "https://github.com/roonga"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"tag": "preview"
	},
	"files": [
		"dist"
	],
	"homepage": "https://github.com/roonga/a2-react-aria/tree/main/packages/core#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/roonga/a2-react-aria.git",
		"directory": "packages/core"
	},
	"bugs": {
		"url": "https://github.com/roonga/a2-react-aria/issues"
	},
	"keywords": [
		"a2ra",
		"a2ui",
		"react-aria",
		"renderer",
		"components",
		"accessibility"
	],
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "vite build && tsc --emitDeclarationOnly --outDir dist",
		"dev": "vite build --watch",
		"gen-schema": "node --experimental-strip-types scripts/gen-schema.mts",
		"build:schema": "node --experimental-strip-types scripts/gen-a2ui-schema.mts",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage --reporter=verbose",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.2",
		"react-aria-components": "^1.18.0",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitejs/plugin-react-swc": "^4.3.1",
		"@vitest/coverage-v8": "^4.1.8",
		"axe-core": "^4.12.1",
		"jsdom": "^26.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"typescript": "6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
