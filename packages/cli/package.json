{
	"name": "@a2ra/cli",
	"version": "1.0.0-preview.3",
	"private": false,
	"description": "Add React Aria a2UI components to your project, shadcn-style — you own the source.",
	"author": {
		"name": "Ravi Mohan",
		"email": "a2-react-aria@roonga.com.au",
		"url": "https://github.com/roonga"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"tag": "preview"
	},
	"type": "module",
	"bin": {
		"a2ra": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"a2ra",
		"a2ui",
		"react-aria",
		"shadcn",
		"cli",
		"components"
	],
	"homepage": "https://github.com/roonga/a2-react-aria/tree/main/packages/cli#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/roonga/a2-react-aria.git",
		"directory": "packages/cli"
	},
	"bugs": {
		"url": "https://github.com/roonga/a2-react-aria/issues"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"dev": "tsc -p tsconfig.json --watch",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage --reporter=verbose",
		"prepublishOnly": "pnpm build"
	},
	"devDependencies": {
		"@types/node": "^20",
