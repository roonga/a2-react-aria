      <div class="gsf-badges" aria-label="Output guarantees">
        <span class="gsf-badge gsf-badge--green">WCAG AA</span>
        <span class="gsf-badge gsf-badge--green">Keyboard nav</span>
        <span class="gsf-badge gsf-badge--green">Screen reader</span>
        <span class="gsf-badge gsf-badge--purple">You own the source</span>
      </div>
