  <div class="gsf-step">
    <span class="gsf-num" aria-hidden="true">01</span>
    <div class="gsf-content">
      <h3 class="gsf-title">Your AI agent emits A2UI JSON</h3>
      <p class="gsf-desc">
        Any model or framework that returns structured JSON works:
        LangGraph, Google ADK, CrewAI, or a plain LLM call.
      </p>
      <div class="gsf-tags" aria-label="Compatible frameworks">
        <span class="gsf-tag">LangGraph</span>
        <span class="gsf-tag">Google ADK</span>
        <span class="gsf-tag">CrewAI</span>
        <span class="gsf-tag">Plain LLM</span>
      </div>
    </div>
    <div class="gsf-visual">
      <div class="gsf-visual-label" aria-hidden="true">agent output</div>
      <pre class="gsf-code" aria-label="Example A2UI JSON output"><span class="j-b">&#123;</span>
  <span class="j-k">"type"</span><span class="j-p">:</span> <span class="j-s">"Form"</span><span class="j-p">,</span>
  <span class="j-k">"children"</span><span class="j-p">: [</span>
    <span class="j-b">&#123;</span>
      <span class="j-k">"type"</span><span class="j-p">:</span> <span class="j-s">"TextField"</span><span class="j-p">,</span>
      <span class="j-k">"props"</span><span class="j-p">: &#123;</span>
        <span class="j-k">"label"</span><span class="j-p">:</span> <span class="j-s">"Email"</span><span class="j-p">,</span>
        <span class="j-k">"isRequired"</span><span class="j-p">:</span> <span class="j-n">true</span>
      <span class="j-p">&#125;</span>
    <span class="j-b">&#125;</span><span class="j-p">,</span>
    <span class="j-b">&#123;</span>
      <span class="j-k">"type"</span><span class="j-p">:</span> <span class="j-s">"Button"</span><span class="j-p">,</span>
      <span class="j-k">"props"</span><span class="j-p">: &#123;</span>
        <span class="j-k">"variant"</span><span class="j-p">:</span> <span class="j-s">"primary"</span><span class="j-p">,</span>
        <span class="j-k">"children"</span><span class="j-p">:</span> <span class="j-s">"Subscribe"</span>
      <span class="j-p">&#125;</span>
    <span class="j-b">&#125;</span>
  <span class="j-p">]</span>
<span class="j-b">&#125;</span></pre>
    </div>
  </div>

